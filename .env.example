PORT=3000
NODE_ENV=development
JWT_SECRET=change-me
ADMIN_SECRET=change-me

# Local PostgreSQL fallback (used when DATABASE_URL is not present)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=dbpass
PGDATABASE=postgres

# Railway/Postgres URL (required in production)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Meta Graph API
META_GRAPH_VERSION=v21.0

# WhatsApp Cloud API
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
